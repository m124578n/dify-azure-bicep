{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "resourceGroupName": "rg-dify-dev",
  "parameters": {
    "location": {
      "value": "japaneast"
    },
    "pgsqlUser": {
      "value": "adminuser"
    },
    "pgsqlPassword": {
      "value": "YOUR_SECURE_PASSWORD_HERE"
    },
    "postgresSkuName": {
      "value": "Standard_B1ms"
    },
    "postgresSkuTier": {
      "value": "Burstable"
    },
    "postgresStorageGB": {
      "value": 32
    },
    "postgresEnableHA": {
      "value": false
    },
    "redisCapacity": {
      "value": 0
    },
    "adminUsername": {
      "value": "azureuser"
    },
    "adminSshPublicKey": {
      "value": "ssh-rsa YOUR_PUBLIC_KEY_HERE"
    },
    "vmSize": {
      "value": "Standard_D4s_v3"
    },
    "nginxVmSize": {
      "value": "Standard_B2s"
    },
    "vmssInstanceCount": {
      "value": 2
    }
  }
}
