{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "resourceGroupName": "rg-dify-dev",
  "parameters": {
    "location": {
      "value": "japaneast"
    },
    "acaInfraRGName": {
      "value": "rg-dify-aca-infra"
    },
    "pgsqlUser": {
      "value": "adminuser"
    },
    "pgsqlPassword": {
      "value": "YOUR_SECURE_PASSWORD_HERE"
    },
    "postgresSkuName": {
      "value": "Standard_B1ms"
    },
    "postgresSkuTier": {
      "value": "Burstable"
    },
    "postgresStorageGB": {
      "value": 32
    },
    "postgresEnableHA": {
      "value": false
    },
    "redisCapacity": {
      "value": 0
    },
    "isProvidedCert": {
      "value": false
    },
    "acaCertPassword": {
      "value": ""
    },
    "acaAppMinCount": {
      "value": 0
    },
    "isAcaEnabled": {
      "value": true
    },
    "apiCpu": {
      "value": "2"
    },
    "apiMemory": {
      "value": "4Gi"
    },
    "workerCpu": {
      "value": "2"
    },
    "workerMemory": {
      "value": "4Gi"
    },
    "webCpu": {
      "value": "1"
    },
    "webMemory": {
      "value": "2Gi"
    }
  }
}
